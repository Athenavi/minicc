# ═══════════════════════════════════════════════════════════════════════════
# MiniCC V3.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
PORT=8080
READ_TIMEOUT=10s
WRITE_TIMEOUT=60s
IDLE_TIMEOUT=120s
LOG_LEVEL=info               # debug / info / warn / error

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── JWT Authentication ───────────────────────────────────────────────────
# Required: minimum 16 characters, use a strong unique value in production.
JWT_SECRET=change-this-to-a-strong-secret-min-16-chars
JWT_EXPIRATION=24h

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DSN=postgres://user:password@localhost:5432/minicc?sslmode=disable
POSTGRES_MAX_CONN=20
POSTGRES_MIN_CONN=2

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── LLM Provider API Keys（Go 侧直连 + Python 引擎共享）──────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
LLM_PROVIDER=openai          # openai / anthropic / deepseek
LLM_MODEL=gpt-4o

# ── Python AI 引擎（内置 LLM Gateway）────────────────────────────────────
PYTHON_ENGINE_ADDRESS=localhost:8000
PYTHON_ENGINE_TIMEOUT=5m

# ── Temporal 工作流引擎 ───────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233

# ── Milvus 向量数据库 ─────────────────────────────────────────────────────
MILVUS_ADDRESS=localhost:19530

# ── File Storage ──────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local / s3
STORAGE_ROOT=./workspace

# ── S3 / MinIO (only needed when STORAGE_BACKEND=s3) ─────────────────────
S3_ENDPOINT=localhost:9000
S3_BUCKET=minicc-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_USE_SSL=false              # true for production S3, false for local MinIO

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_RPM=100            # requests per minute per user
RATE_LIMIT_GLOBAL=10000       # global requests per minute

# ── Agent 配置 ────────────────────────────────────────────────────────────
AGENT_MAX_TURNS=10            # 最大推理轮数
AGENT_MAX_TOKENS=4096         # 每次 LLM 调用最大输出 Token
AGENT_CONTEXT_LIMIT=20        # 上下文消息数量限制

# ── Stripe (计费) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=price_1000_credits

# ── PayPal (计费) ─────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# Python AI 引擎独立配置 (python-engine/.env)
# ═══════════════════════════════════════════════════════════════════════════
