# ═══════════════════════════════════════════════════════════════════════════
# MiniCC V2.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
PORT=8080
READ_TIMEOUT=10s
WRITE_TIMEOUT=60s
IDLE_TIMEOUT=120s
LOG_LEVEL=info               # debug / info / warn / error

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── JWT Authentication ───────────────────────────────────────────────────
# Required: minimum 16 characters, use a strong unique value in production.
JWT_SECRET=change-this-to-a-strong-secret-min-16-chars
JWT_EXPIRATION=24h

# ── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_DSN=postgres://user:password@localhost:5432/minicc?sslmode=disable
POSTGRES_MAX_CONN=50
POSTGRES_MIN_CONN=10

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── LLM / AI Provider ────────────────────────────────────────────────────
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.openai.com
LLM_MODEL=gpt-4o
LLM_PROVIDER=openai          # openai / anthropic / local

# ── File Storage ──────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local / s3
STORAGE_ROOT=./workspace

# ── S3 / MinIO (only needed when STORAGE_BACKEND=s3) ─────────────────────
S3_ENDPOINT=play.min.io
S3_BUCKET=minicc
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_RPM=100            # requests per minute per user
RATE_LIMIT_GLOBAL=10000       # global requests per minute
